rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // =====================
    // USERS (пользователи)
    // =====================
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // =====================
    // USERNAMES (проверка уникальности имени пользователя)
    // =====================
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // =====================
    // LIKES (лайки) - НОВОЕ
    // =====================
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if request.auth != null 
        && resource.data.fromUserId == request.auth.uid;
    }

    // =====================
    // MATCHES (взаимные лайки) - НОВОЕ
    // =====================
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
        && request.auth.uid in resource.data.userIds;
    }

    // =====================
    // REPORTS (жалобы на пользователей) - НОВОЕ
    // =====================
    match /reports/{reportId} {
      allow read: if request.auth != null 
        && (resource.data.reporterId == request.auth.uid || request.auth.uid == 'admin_user_id');
      allow create: if request.auth != null 
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reportedUserId is string
        && request.resource.data.reason is string
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if request.auth != null 
        && resource.data.reporterId == request.auth.uid;
    }

    // =====================
    // CONVERSATIONS (чаты)
    // =====================
    match /conversations/{convId} {
      allow read: if (resource.data.isPrivate == false)
        || (request.auth != null
          && (
            request.auth.uid in resource.data.memberIds
            || request.auth.uid in request.resource.data.memberIds
          ));
      allow update, delete: if request.auth != null
        && (
          request.auth.uid in resource.data.memberIds
          || request.auth.uid in request.resource.data.memberIds
        );
      allow create: if request.auth != null
        && request.resource.data.memberIds.hasAny([request.auth.uid]);
      
      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.memberIds;
        allow write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.memberIds
          && (
            (
              get(/databases/$(database)/documents/conversations/$(convId)).data.type == "channel"
              && get(/databases/$(database)/documents/conversations/$(convId)).data.roles[request.auth.uid] in ["owner", "admin"]
            )
            || (
              get(/databases/$(database)/documents/conversations/$(convId)).data.type == "group"
              && (
                get(/databases/$(database)/documents/conversations/$(convId)).data.postPermission != "admins"
                || get(/databases/$(database)/documents/conversations/$(convId)).data.roles[request.auth.uid] in ["owner", "admin"]
              )
            )
            || (
              get(/databases/$(database)/documents/conversations/$(convId)).data.type != "channel"
              && get(/databases/$(database)/documents/conversations/$(convId)).data.type != "group"
            )
            || (
              resource.data.senderId == request.auth.uid
              && request.resource.data.deleted == true
            )
          );
      }
    }

    // =====================
    // STORIES (истории)
    // =====================
    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // =====================
    // STORY VIEWS (просмотры историй)
    // =====================
    match /storyViews/{viewId} {
      allow read: if request.auth != null && request.resource.data.viewerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.viewerId == request.auth.uid
        && request.resource.data.storyId is string
        && exists(/databases/$(database)/documents/stories/$(request.resource.data.storyId));
      allow update, delete: if false;
    }

    // =====================
    // INVITES (приглашения в чаты)
    // =====================
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && request.resource.data.conversationId is string
        && get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.roles[request.auth.uid] in ["owner", "admin"];
    }

    // =====================
    // STICKER PACKS (паки стикеров)
    // =====================
    match /stickerPacks/{packId} {
      allow read: if resource.data.isPrivate == false
        || (request.auth != null
          && (
            request.auth.uid == resource.data.creatorId
            || exists(/databases/$(database)/documents/users/$(request.auth.uid)/stickerPacks/$(packId))
          ));
      allow create: if request.auth != null
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.nameLower is string
        && request.resource.data.isPrivate is bool;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.creatorId;
      
      match /stickers/{stickerId} {
        allow read: if get(/databases/$(database)/documents/stickerPacks/$(packId)).data.isPrivate == false
          || (request.auth != null
            && (
              request.auth.uid == get(/databases/$(database)/documents/stickerPacks/$(packId)).data.creatorId
              || exists(/databases/$(database)/documents/users/$(request.auth.uid)/stickerPacks/$(packId))
            ));
        allow create, update, delete: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/stickerPacks/$(packId)).data.creatorId;
      }
    }

    // =====================
    // APP METADATA (метаданные приложения)
    // =====================
    match /app/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
